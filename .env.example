# CardOps AI local defaults
CARDOPS_ENV=development
CARDOPS_DATABASE_URL=sqlite:///./data/cardops.db
CARDOPS_DATA_DIR=./data
CARDOPS_API_HOST=127.0.0.1
CARDOPS_API_PORT=8000
CARDOPS_WEB_PORT=5173
CARDOPS_DEMO_MODE=true
CARDOPS_LOG_LEVEL=INFO
CARDOPS_DEFAULT_INPUT_DIR=
CARDOPS_DEFAULT_OUTPUT_DIR=./data/exports
CARDOPS_INVENTORY_PATH=./data/exports/cardops-inventory.csv
CARDOPS_EBAY_EXPORT_PATH=./data/exports/cardops-ebay-listings.csv

# Privacy and safety defaults
CARDOPS_LOCAL_ONLY_MODE=true
CARDOPS_CLOUD_AI_ENABLED=false
CARDOPS_LIVE_EBAY_PUBLISHING_ENABLED=false
CARDOPS_PHYSICAL_FILE_MOVES_ENABLED=false
CARDOPS_LISTING_EXPORT_MODE=file_upload
CARDOPS_EBAY_DIRECT_LISTING_ENABLED=false
CARDOPS_EBAY_SYNC_LIMIT=25
CARDOPS_EBAY_SYNC_OFFSET=0
CARDOPS_EBAY_SYNC_INCLUDE_OFFERS=true

# Optional OpenAI configuration. Leave unset for local-only mode.
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4.1-mini
OPENAI_MODEL_ACCURATE=gpt-4.1

# Local OCR configuration. Leave CARDOPS_TESSERACT_CMD empty to use PATH detection.
# The launcher/code also checks E:\Apps\tesseract-ocr\tesseract.exe on Windows.
CARDOPS_TESSERACT_CMD=E:\Apps\tesseract-ocr\tesseract.exe
CARDOPS_OCR_LANGUAGE=eng
CARDOPS_CONFIDENCE_THRESHOLD=0.72
CARDOPS_DEFAULT_LISTING_FORMAT=fixed_price

# Optional eBay configuration. Leave unset for mock/offline mode.
EBAY_ENVIRONMENT=sandbox
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=https://940smiley.github.io/cardops/ebay/callback/
EBAY_AUTH_ACCEPTED_URL=https://940smiley.github.io/cardops/ebay/callback/
EBAY_AUTH_DECLINED_URL=https://940smiley.github.io/cardops/ebay/callback/
# eBay calls this the Redirect URL name / RuName. The authorization URL should use this value.
EBAY_RUNAME=
EBAY_SCOPES=https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.inventory
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_MERCHANT_LOCATION_KEY=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_FULFILLMENT_POLICY_ID=

# Frontend API base
VITE_API_BASE_URL=http://127.0.0.1:8000
